# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://mediapipeline:mediapipeline@localhost:5432/mediapipeline?schema=public"

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Queue
QUEUE_NAME=analysis-queue
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_MS=2000

# Image analysis thresholds
BLUR_VARIANCE_THRESHOLD=100
BRIGHTNESS_MIN=40
BRIGHTNESS_MAX=220

# Logging
LOG_LEVEL=info
