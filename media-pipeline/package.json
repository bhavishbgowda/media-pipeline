{
  "name": "intelligent-media-processing-pipeline",
  "version": "1.0.0",
  "description": "Async backend pipeline for vehicle image ingestion, quality analysis, and result retrieval.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/analysis.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:migrate": "npx prisma migrate deploy && node dist/server.js",
    "start:worker": "node dist/workers/analysis.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "bullmq": "^5.12.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "sharp": "^0.33.4",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.15",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.19.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.5.4"
  }
}
